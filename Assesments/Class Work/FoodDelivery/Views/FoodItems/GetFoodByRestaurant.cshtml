@model IEnumerable<FoodDelivery.Models.FoodItem>

<h2>Food Items by Restaurant</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>RestaurantId</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.RestaurantId</td>
            </tr>
        }
    </tbody>
</table>

