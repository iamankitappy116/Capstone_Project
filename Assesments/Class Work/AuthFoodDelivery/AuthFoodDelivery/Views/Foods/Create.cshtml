@model FoodDeliveryApp.Models.Food

@{
    ViewData["Title"] = "Create Food";
}

<h1>Create Food</h1>

<h4>Food Details</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <!-- IMPORTANT: Explicitly specify controller and action -->
        <form asp-controller="Foods" asp-action="Create" method="post" enctype="multipart/form-data">

            <!-- Anti-forgery token for security -->
            @Html.AntiForgeryToken()

            <!-- Shows validation errors -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Category Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="categId" class="control-label"></label>

                <select asp-for="categId"
                        asp-items="ViewBag.categId"
                        class="form-control">
                    <option value="">-- Select Category --</option>
                </select>

                <span asp-validation-for="categId" class="text-danger"></span>
            </div>

            <!-- Name -->
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>

                <input asp-for="Name"
                       class="form-control"
                       placeholder="Enter food name" />

                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Description -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>

                <input asp-for="Description"
                       class="form-control"
                       placeholder="Enter description" />

                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Price -->
            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label"></label>

                <input asp-for="Price"
                       class="form-control"
                       placeholder="Enter price" />

                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Food Image</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
            </div>

            <!-- Submit button -->
            <div class="form-group mb-3">
                <input type="submit"
                       value="Create Food"
                       class="btn btn-primary" />

                <a asp-controller="Foods"
                       asp-action="Index"
                       class="btn btn-secondary ms-2">
                    Back to List
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
