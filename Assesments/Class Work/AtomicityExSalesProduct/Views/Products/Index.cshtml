@model IEnumerable<AtomicityExSalesProduct.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2>Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.First().Name)</th>
            <th>@Html.DisplayNameFor(m => m.First().Price)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@Html.DisplayFor(_ => product.Name)</td>
                <td>@Html.DisplayFor(_ => product.Price)</td>
                <td>
                    <a asp-action="Edit"      asp-route-id="@product.Id">Edit</a> |
                    <a asp-action="Details"   asp-route-id="@product.Id">Details</a> |
                    <a asp-action="Delete"    asp-route-id="@product.Id">Delete</a> |
                    <a asp-action="AddToCart" asp-route-id="@product.Id">Add to Cart</a>
                </td>
            </tr>
        }
    </tbody>
</table>
