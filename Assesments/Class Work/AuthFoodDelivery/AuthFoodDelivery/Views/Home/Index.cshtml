@{
    ViewData["Title"] = "Home Page";
}

<div class="mt-4">
    @if (User.IsInRole("Admin"))
    {
        <div class="border-bottom pb-3 mb-4">
            <h2>Admin Dashboard</h2>
            <p>Welcome, Administrator. Manage the restaurant menu and orders below.</p>
            <div class="btn-group">
                <a class="btn btn-outline-primary" asp-controller="Foods" asp-action="Index">Manage Menu</a>
                <a class="btn btn-outline-info" asp-controller="Categories" asp-action="Index">Categories</a>
                <a class="btn btn-outline-success" asp-controller="Sales" asp-action="Index">All Orders</a>
            </div>
        </div>
    }
    else if (User.Identity.IsAuthenticated)
    {
        <div class="border-bottom pb-3 mb-4">
            <h2>Welcome, @User.Identity.Name!</h2>
            <p>Manage your orders and explore our delicious menu.</p>
            <div class="btn-group">
                <a class="btn btn-success" asp-controller="Foods" asp-action="Index">Order Now</a>
                <a class="btn btn-info text-white" asp-controller="Foods" asp-action="Filter">Filter by Category</a>
                <a class="btn btn-primary" asp-controller="Carts" asp-action="Index">My Cart</a>
                <a class="btn btn-secondary" asp-controller="Sales" asp-action="Index">Order History</a>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h1 class="display-5">Welcome to AuthFoodDelivery</h1>
            <p class="lead">Fresh, fast, and straight to your door.</p>
            <div class="mt-4">
                <a class="btn btn-primary px-4" asp-area="Identity" asp-page="/Account/Login">Login</a>
                <a class="btn btn-outline-secondary px-4" asp-area="Identity" asp-page="/Account/Register">Register</a>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-4">
            <h4>Fresh Ingredients</h4>
            <p>Quality dishes made from the freshest local sources.</p>
        </div>
        <div class="col-md-4">
            <h4>Fast Delivery</h4>
            <p>Quick and efficient service to your doorstep.</p>
        </div>
        <div class="col-md-4">
            <h4>Best Prices</h4>
            <p>Top-tier meals at affordable prices.</p>
        </div>
    </div>
</div>
